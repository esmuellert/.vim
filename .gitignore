# Ignore everything by default
/*

# Tracked top-level files
!/.gitignore
!/.luarc.json
!/.stylua.toml
!/.tmux.conf
!/home.nix
!init.lua
!lazy-lock.json

# Tracked directories
!/lua/
!/scripts/
!/dev-docs/

# Machine-specific / local overrides (not tracked)
/lua/local.lua
/lua/plugin/
/lua/plugins/local-dev.lua

# Documentation and assets
!*.md
!*.png
